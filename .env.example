# Variáveis do backend ML (Docker local). Copie para .env e preencha.

# --- Mercado Livre OAuth ---
ML_CLIENT_ID=
ML_CLIENT_SECRET=
# OBS: o ML só aceita redirect HTTPS público. Para testes em produção, use um
# tunelamento (ex.: ngrok/cloudflared) apontando para http://localhost:3001 e
# coloque a URL https resultante aqui (com path /api/ml/callback).
ML_REDIRECT_URI=http://localhost:3001/api/ml/callback

# --- Banco de dados (Postgres local em Docker) ---
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ml_dashboard
# DB_SSL=1  # apenas se usar Postgres gerenciado externo

# --- Redis local em Docker ---
REDIS_URL=redis://redis:6379

# --- Admin (api/ml/token.js) ---
ADMIN_KEY=
